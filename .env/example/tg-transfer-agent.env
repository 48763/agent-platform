HUB_URL=http://hub:9000
AGENT_HOST=tg-transfer-agent
AGENT_PORT=8011
DATA_DIR=/data/tg_transfer
SESSION_DIR=/data/session

# Telegram auth
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-api-hash-here

# LLM (set API key OR use `gemini auth login` in container)
LLM=gemini
# GEMINI_API_KEY=your-gemini-api-key-here

# Transfer settings (defaults in agent.yaml, env vars override)
DEFAULT_TARGET_CHAT=
RETRY_LIMIT=3
PROGRESS_INTERVAL=20
TELETHON_SESSION=bot_session
LIVENESS_CHECK_INTERVAL=24
SEARCH_PAGE_SIZE=10
PHASH_THRESHOLD=10
