ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Hub server
HUB_HOST=0.0.0.0
HUB_PORT=9000
HEARTBEAT_TIMEOUT=30

# Gemini models
GEMINI_FAST_MODEL=gemini-2.5-flash
