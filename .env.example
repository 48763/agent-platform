ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Gateway mode: "bot" (BotFather) or "userbot" (personal account)
GATEWAY_MODE=userbot

# --- Bot mode (GATEWAY_MODE=bot) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Userbot mode (GATEWAY_MODE=userbot) ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-api-hash-here
TELEGRAM_PHONE=+886912345678
# Optional: restrict to specific chat IDs (comma-separated)
# ALLOWED_CHATS=123456789,-100123456789
